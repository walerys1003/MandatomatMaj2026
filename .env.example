# =============================================================================
# Mandatomat — Environment variables (template)
# =============================================================================
#
# Copy to `.env.local` (apps/web) for local dev — NEVER commit a real .env.
# Production secrets live in Vercel Project Settings → Environment Variables.
#
# Source: knowledge base chunk T02_architektura_stack + docs/RUNBOOK.md sec. 4
# -----------------------------------------------------------------------------

# --- Node ---
NODE_ENV=development

# --- Supabase ---------------------------------------------------------------
# Lokalnie: `supabase start` daje gotowe wartości (kopiuj z outputu).
# Produkcja: project-settings → API w dashboardzie supabase.com.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...example-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...example-service-role

# --- Anthropic (Claude) -----------------------------------------------------
# Sonnet 4.6 = generation, Haiku 4.5 = scoring/validation
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_GENERATION=claude-sonnet-4-6
ANTHROPIC_MODEL_SCORING=claude-haiku-4-5

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email / SMS ------------------------------------------------------------
RESEND_API_KEY=re_...
SMSAPI_TOKEN=

# --- Fakturownia (PL invoicing) ---------------------------------------------
FAKTUROWNIA_API_KEY=
FAKTUROWNIA_DOMAIN=mandatomat

# --- Upstash Redis (rate limit) ---------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Inngest (background jobs: OCR, async generation) -----------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=mandatomat-prod
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# --- Cron / internal ----------------------------------------------------------
# Generate: openssl rand -hex 32
CRON_SECRET=

# --- Crypto -----------------------------------------------------------------
# AES-256 key for PESEL encryption. Min 32 chars, hex preferred.
# Generate: openssl rand -hex 32
PESEL_ENCRYPTION_KEY=

# --- Public app config ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Mandatomat
